<?xml version="1.0" encoding="UTF-8"?>
<!--
  Hosted at: https://tabtypist.com/appcast.xml
  Referenced by: Resources/Info.plist  SUFeedURL key

  To update after a release:
    1. Run: bash scripts/generate-appcast-entry.sh v<version>
    2. Replace the <item> below with the one from dist/appcast-entry.xml
    3. Deploy this file to https://tabtypist.com/appcast.xml

  The sparkle:edSignature is generated by scripts/generate-appcast-entry.sh
  using the EdDSA private key stored in the SPARKLE_PRIVATE_KEY CI secret.
  The matching public key is in Resources/Info.plist (SUPublicEDKey).
-->
<rss xmlns:sparkle="http://www.andymatuschak.org/xml-namespaces/sparkle" version="2.0">
    <channel>
        <title>TabTypist Changelog</title>
        <link>https://tabtypist.com/appcast.xml</link>
        <description>Most recent changes.</description>
        <language>en</language>
        <!-- Replace this item with the output of scripts/generate-appcast-entry.sh -->
        <item>
            <title>Version 0.1.0</title>
            <sparkle:version>1</sparkle:version>
            <sparkle:shortVersionString>0.1.0</sparkle:shortVersionString>
            <pubDate>PLACEHOLDER_PUBDATE</pubDate>
            <enclosure
                url="https://github.com/tabtypist/TabTypist/releases/download/v0.1.0/TabTypist.dmg"
                sparkle:edSignature="PLACEHOLDER_EDSIGNATURE"
                length="PLACEHOLDER_SIZE_BYTES"
                type="application/octet-stream"/>
        </item>
    </channel>
</rss>

<?xml version="1.0" encoding="UTF-8"?>
<!--
  Reference snapshot. The LIVE feed is generated by scripts/generate-appcast-entry.sh
  during release.yml and uploaded as an `appcast.xml` asset on each GitHub release.

  Served at (SUFeedURL in Resources/Info.plist):
    https://github.com/mmexploit/TabTypist/releases/latest/download/appcast.xml

  GitHub's /releases/latest/ resolves only to non-prerelease releases, so release.yml
  publishes with prerelease: false (the title still marks the beta).

  The sparkle:edSignature is over the DMG bytes (not the URL), produced with the EdDSA
  private key in the SPARKLE_PRIVATE_KEY CI secret. The matching public key is in
  Resources/Info.plist (SUPublicEDKey).
-->
<rss xmlns:sparkle="http://www.andymatuschak.org/xml-namespaces/sparkle" version="2.0">
    <channel>
        <title>TabTypist Changelog</title>
        <link>https://github.com/mmexploit/TabTypist/releases/latest/download/appcast.xml</link>
        <description>Most recent changes.</description>
        <language>en</language>
